{
  "name": "delivery-app",
  "version": "1.0.0",
  "description": "Real-time delivery order tracking app",
  "license": "ISC",
  "author": "",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev:help",
    "dev:help": "echo \"Run backend and frontend separately: npm run dev:backend, then npm run dev:frontend\"",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "start": "npm run start --workspace backend",
    "start:prod": "npm run start:prod --workspace backend",
    "build": "npm run build --workspace frontend",
    "preview": "npm run preview --workspace frontend",
    "check": "npm run check --workspace backend && npm run check --workspace frontend"
  }
}
